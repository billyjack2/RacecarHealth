{
  "name": "racecarhealth",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @racecarhealth/db generate",
    "db:migrate": "pnpm --filter @racecarhealth/db migrate",
    "db:studio": "pnpm --filter @racecarhealth/db studio"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.2",
    "vercel": "^54.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
